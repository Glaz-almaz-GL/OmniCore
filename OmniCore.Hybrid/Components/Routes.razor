@using System.Diagnostics
@using System.Reflection

<Router AppAssembly="@typeof(App).Assembly" AdditionalAssemblies="@AdditionalAssemblies">
	<Found Context="routeData">
		<RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
		<FocusOnNavigate RouteData="@routeData" Selector="h1" />
	</Found>
	<NotFound>
		<PageTitle>Not found</PageTitle>
		<LayoutView Layout="@typeof(MainLayout)">
			<p role="alert">Sorry, there's nothing at this address.</p>
		</LayoutView>
	</NotFound>
</Router>

@code {
	[Inject] private NavigationManager NavigationManager { get; set; } = default!;

	private IEnumerable<Assembly> AdditionalAssemblies =>
		AppDomain.CurrentDomain.GetAssemblies()
			.Where(a => a.GetName().Name?.StartsWith("OmniCore.Modules") == true);

	protected override void OnInitialized()
	{
		Debug.WriteLine($"[App] App.razor инициализирован. Загружено сборок: {AdditionalAssemblies.Count()}");

		base.OnInitialized();
	}
}