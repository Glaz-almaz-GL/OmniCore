@inherits LayoutComponentBase
@using OmniCore.Core.Interfaces
@using OmniCore.Hybrid.Interfaces
@using System.Globalization
@using Microsoft.Extensions.Localization
@using OmniCore.Hybrid.Resources
@using OmniCore.Hybrid.Models
@inject IModuleManager ModuleManager
@inject IAppSettingsService AppSettings
@inject NavigationManager NavManager
@inject IStringLocalizer<SharedResources> Localizer
@inject ILayoutStateService LayoutStateService
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider" Theme="@_customTheme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
	<!-- Верхняя панель приложения -->
	<MudAppBar Dense="true" Elevation="1" Color="Color.Primary">
		<MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
		<MudText Typo="Typo.h6" Class="ml-2">Omni Core</MudText>
		<MudSpacer />

		<!-- Переключатель языка -->
		<MudSelect T="string" @bind-Value="CurrentCulture" Variant="Variant.Text" Class="mr-2" Style="width: 100px;">
			<MudSelectItem Value="@("ru-RU")">Русский</MudSelectItem>
			<MudSelectItem Value="@("en-US")">English</MudSelectItem>
		</MudSelect>

		<!-- Переключатель темы -->
		<MudSelect T="Models.ThemeMode"
				   ValueChanged="async (Models.ThemeMode val) =>
									  {
										  AppSettings.Settings.ThemeMode = val;
										  await ToggleThemeAsync();
										  await SaveSettingsAsync();
									  }"
				   Variant="Variant.Text"
				   Value="@AppSettings.Settings.ThemeMode">
			<MudSelectItem Value="@ThemeMode.Dark">
				<MudStack Row="true">
					<MudIcon Icon="@Icons.Material.Filled.DarkMode" />
					Dark
				</MudStack>
			</MudSelectItem>
			<MudSelectItem Value="@ThemeMode.Light">
				<MudStack Row="true">
					<MudIcon Icon="@Icons.Material.Filled.LightMode" />
					Light
				</MudStack>
			</MudSelectItem>
			<MudSelectItem Value="@ThemeMode.System">
				<MudStack Row="true">
					<MudIcon Icon="@Icons.Material.Filled.AutoMode" />
					System
				</MudStack>
			</MudSelectItem>
		</MudSelect>
	</MudAppBar>

	<!-- Боковое меню навигации -->
	<MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
		<MudNavMenu>
			@foreach (var module in _activeModules.OrderBy(m => m.Title))
			{
				try
				{
					var items = module.GetNavigationItems();
					if (items == null || !items.Any())
					{
						continue;
					}

					<MudNavGroup Title="@module.Title" Icon="@module.Icon" Expanded="true">
						@foreach (var item in items)
						{
							try
							{
								var fullRoute = GetFullRoute(module, item);

								if (AppSettings.IsRouteEnabled(fullRoute))
								{
									<MudNavLink Href="@fullRoute"
												Icon="@item.Icon"
												Match="NavLinkMatch.Prefix"
												IconColor="Color.Primary">
										@item.Title
									</MudNavLink>
								}
							}
							catch (Exception ex)
							{
								System.Diagnostics.Debug.WriteLine($"[Layout] Error rendering nav item: {ex.Message}");
							}
						}
					</MudNavGroup>
				}
				catch (Exception ex)
				{
					System.Diagnostics.Debug.WriteLine($"[Layout] Error rendering module {module.Title}: {ex.Message}");
				}
			}

			<MudDivider Class="my-4" />

			<MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" Match="NavLinkMatch.Prefix">
				@Localizer["Settings_Title"]
			</MudNavLink>
		</MudNavMenu>
	</MudDrawer>

	<!-- Основной контент страницы -->
	<MudMainContent>
		@Body
	</MudMainContent>
</MudLayout>

@code {
	private bool _drawerOpen = true;
	private bool _isDarkMode = false;
	private bool _isLoaded = false;
	private MudThemeProvider? _mudThemeProvider;
	private IReadOnlyCollection<IModule> _activeModules = [];

	private readonly MudTheme _customTheme = new()
	{
		PaletteDark = new PaletteDark()
		{
			TableStriped = MudBlazor.Utilities.MudColor.Parse("32323b"),
			TableHover = MudBlazor.Utilities.MudColor.Parse("2c2c33")
		}
	};

	private string CurrentCulture
	{
		get => CultureInfo.CurrentCulture.Name;
		set
		{
			if (CultureInfo.CurrentCulture.Name != value)
			{
				var culture = new CultureInfo(value);
				ChangeCultureInfo(culture);

				AppSettings.Settings.Language = value;
				_ = SaveSettingsAsync();

				if (_isLoaded)
				{
					NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
				}
				else
				{
					StateHasChanged();
				}
			}
		}
	}

	protected override async Task OnInitializedAsync()
	{
		await AppSettings.LoadAsync();

		// Подписываемся на события ModuleManager для реактивного обновления UI
		ModuleManager.ModuleStateChanged += OnModuleStateChanged;
		ModuleManager.ModulesBulkRegistered += OnModulesBulkRegistered;

		LayoutStateService.OnStateChanged += InvokeStateHasChanged;

		// Загружаем активные модули
		_activeModules = ModuleManager.GetActiveModules();

		// Применяем сохраненный язык до первой отрисовки
		if (!string.IsNullOrEmpty(AppSettings.Settings.Language) &&
			AppSettings.Settings.Language != CultureInfo.CurrentCulture.Name)
		{
			var culture = new CultureInfo(AppSettings.Settings.Language);
			ChangeCultureInfo(culture);
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender && _mudThemeProvider != null)
		{
			if (AppSettings.Settings.ThemeMode == Models.ThemeMode.System)
			{
				_isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
			}
			else
			{
				await ToggleThemeAsync();
			}

			_isLoaded = true;
			StateHasChanged();
		}
	}

	private void ChangeCultureInfo(CultureInfo cultureInfo)
	{
		CultureInfo.CurrentCulture = cultureInfo;
		CultureInfo.CurrentUICulture = cultureInfo;
		CultureInfo.DefaultThreadCurrentCulture = cultureInfo;
		CultureInfo.DefaultThreadCurrentUICulture = cultureInfo;
	}

	private void OnModuleStateChanged(IModule module)
	{
		// Обновляем список активных модулей при изменении состояния
		_activeModules = ModuleManager.GetActiveModules();
		InvokeAsync(StateHasChanged);
	}

	private void OnModulesBulkRegistered(IReadOnlyCollection<IModule> modules)
	{
		// Обновляем список активных модулей при пакетной регистрации
		_activeModules = ModuleManager.GetActiveModules();
		InvokeAsync(StateHasChanged);
	}

	private async Task SaveSettingsAsync()
	{
		try
		{
			await AppSettings.SaveAsync();
		}
		catch (Exception ex)
		{
			System.Diagnostics.Debug.WriteLine($"[Settings] Error saving settings: {ex.Message}");
		}
	}

	private void InvokeStateHasChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		ModuleManager.ModuleStateChanged -= OnModuleStateChanged;
		ModuleManager.ModulesBulkRegistered -= OnModulesBulkRegistered;
		LayoutStateService.OnStateChanged -= InvokeStateHasChanged;
	}

	private void ToggleDrawer()
	{
		_drawerOpen = !_drawerOpen;
	}

	private async Task ToggleThemeAsync()
	{
		if (_mudThemeProvider == null) return;

		switch (AppSettings.Settings.ThemeMode)
		{
			case Models.ThemeMode.Dark:
				_isDarkMode = true;
				break;
			case Models.ThemeMode.Light:
				_isDarkMode = false;
				break;
			case Models.ThemeMode.System:
				_isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
				break;
		}
	}

	private string GetFullRoute(IModule module, INavigationItem item)
	{
		return $"{module.BaseRoute.TrimEnd('/')}/{item.RelativeRoute.TrimStart('/')}";
	}
}