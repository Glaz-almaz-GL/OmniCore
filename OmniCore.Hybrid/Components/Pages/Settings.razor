@page "/settings"
@using OmniCore.Core.Interfaces
@using Microsoft.Extensions.Localization
@using OmniCore.Hybrid.Interfaces
@using System.Diagnostics
@using OmniCore.Hybrid.Resources
@inject IAppSettingsService AppSettings
@inject IModuleManager ModuleManager
@inject IStringLocalizer<SharedResources> Localizer
@inject ISnackbar Snackbar
@inject ILayoutStateService LayoutStateService
@inject NavigationManager NavManager
@implements IDisposable

<MudContainer  MaxWidth="MaxWidth.Medium" Class="mt-4">
	<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 600;">@Localizer["Settings_Title"]</MudText>

	<MudTabs Elevation="1" Border="true" Rounded="true" ApplyEffectsToContainer="false">

		<!-- Вкладка 1: Общие настройки приложения -->
		<MudTabPanel  Text="@Localizer["Settings_Tab_General"]" Icon="@Icons.Material.Filled.Settings">
			<MudStack Spacing="4">

				<!-- Секция: Видимость модулей и страниц -->
				<MudCard>
					<MudCardHeader>
						<CardHeaderContent>
							<MudText Typo="Typo.h6">@Localizer["Settings_Visibility_Title"]</MudText>
							<MudText Typo="Typo.body2" Color="Color.Secondary">@Localizer["Settings_Visibility_Description"]</MudText>
						</CardHeaderContent>
					</MudCardHeader>
					<MudCardContent>
						<MudStack Spacing="2">
							@foreach (var module in _registeredModules.OrderBy(m => m.Title))
							{
								try
								{
									var moduleRoute = module.BaseRoute;
									var isModuleEnabled = ModuleManager.IsEnabled(module);
									var modulePages = module.GetNavigationItems();

									<MudPaper Square="true" Outlined="true">
										<MudExpansionPanel>
											<TitleContent>
												<MudStack Row="true" AlignItems="AlignItems.Center" Class="justify-space-between flex-wrap gap-3">
													<MudStack Row="true" AlignItems="AlignItems.Start" Class="flex-wrap gap-3">
														<MudIcon Icon="@module.Icon" Color="Color.Primary" />
														<div>
															<MudText Typo="Typo.body1">@module.Title</MudText>
															<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">@module.Description</MudText>
															<MudText Typo="Typo.caption" Class="mt-1">@module.BaseRoute</MudText>
														</div>
													</MudStack>
													<MudSwitch T="bool"
															   ValueChanged="@(async (val) => await ToggleModuleAsync(module, val))"
															   Value="@isModuleEnabled"
															   Label="@Localizer["Settings_EnableModule"]"
															   Color="Color.Primary" />
												</MudStack>
											</TitleContent>
											<ChildContent>
												<MudStack Spacing="2">
													@if (!isModuleEnabled)
													{
														<MudText Typo="Typo.body2" Color="Color.Warning">@Localizer["Settings_ModuleDisabledDescription"]</MudText>
													}

													@if (modulePages == null || modulePages.Count == 0)
													{
														<MudPaper Outlined="true" Class="pa-4">
															<MudText Typo="Typo.body2" Color="Color.Secondary">@Localizer["Settings_ModuleDisabled"]</MudText>
														</MudPaper>
													}
													else
													{
														@foreach (var modulePage in modulePages)
														{
															try
															{
																var fullRoute = GetFullRoute(module, modulePage);
																var isPageEnabled = AppSettings.IsRouteEnabled(fullRoute);

																<MudPaper Outlined="true" Class="pa-3">
																	<MudStack Row="true" AlignItems="AlignItems.Center" Class="justify-space-between flex-wrap gap-3">
																		<MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap gap-3">
																			<MudIcon Icon="@modulePage.Icon" Color="Color.Secondary" />
																			<div>
																				<MudText Typo="Typo.body1">@modulePage.Title</MudText>
																				<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">@modulePage.Description</MudText>
																				<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@fullRoute</MudText>
																			</div>
																		</MudStack>
																		<MudSwitch T="bool"
																				   Value="@isPageEnabled"
																				   ValueChanged="@(async (val) => await TogglePageAsync(fullRoute, val))"
																				   Color="Color.Secondary" />
																	</MudStack>
																</MudPaper>
															}
															catch (Exception ex)
															{
																System.Diagnostics.Debug.WriteLine($"[Settings] Error rendering page: {ex.Message}");
															}
														}
													}
												</MudStack>
											</ChildContent>
										</MudExpansionPanel>
									</MudPaper>
								}
								catch (Exception ex)
								{
									System.Diagnostics.Debug.WriteLine($"[Settings] Error rendering module: {ex.Message}");
								}
							}
						</MudStack>
					</MudCardContent>
				</MudCard>
			</MudStack>
		</MudTabPanel>

		<!-- Вкладки 2+: Настройки конкретных модулей (Динамическая генерация) -->
		@foreach (var provider in _settingsProviders)
		{
			try
			{
				<MudTabPanel Text="@provider.ModuleName" Icon="@provider.Icon">
					<DynamicComponent Type="@provider.SettingsComponentType" />
				</MudTabPanel>
			}
			catch (Exception ex)
			{
				System.Diagnostics.Debug.WriteLine($"[Settings] Error rendering settings provider: {ex.Message}");
			}
		}

	</MudTabs>
</MudContainer>

@code {
	private IReadOnlyCollection<IModule> _registeredModules = [];
	private IReadOnlyList<IModuleSettingsProvider> _settingsProviders = [];

	protected override void OnInitialized()
	{
		// Подписываемся на события для реактивного обновления
		ModuleManager.ModuleStateChanged += OnModuleStateChanged;
		ModuleManager.ModulesBulkRegistered += OnModulesBulkRegistered;

		// Загружаем данные модулей
		LoadModuleData();
	}

	private void LoadModuleData()
	{
		_registeredModules = ModuleManager.GetRegisteredModules();

		_settingsProviders = _registeredModules
					.Where(m => m is IModuleSettingsProvider)
					.Select(m => (IModuleSettingsProvider)m)
					.ToList()
					.AsReadOnly();

		foreach (var provider in _settingsProviders)
		{
			Debug.WriteLine($"[Settings] Loaded provider: {provider.ModuleName}");
		}
	}

	private void OnModuleStateChanged(IModule module)
	{
		InvokeAsync(StateHasChanged);
	}

	private void OnModulesBulkRegistered(IReadOnlyCollection<IModule> modules)
	{
		LoadModuleData();
		InvokeAsync(StateHasChanged);
	}

	/// <summary>
	/// Переключает состояние модуля через ModuleManager
	/// </summary>
	private async Task ToggleModuleAsync(IModule module, bool isEnabled)
	{
		try
		{
			if (isEnabled)
			{
				ModuleManager.EnableModule(module);
			}
			else
			{
				ModuleManager.DisableModule(module);
			}

			await AppSettings.SaveAsync();
			LayoutStateService.NotifyStateChanged();
			Snackbar.Add(Localizer["Settings_Saved_Success"], Severity.Success);
		}
		catch (Exception ex)
		{
			System.Diagnostics.Debug.WriteLine($"[Settings] Error toggling module: {ex.Message}");
			Snackbar.Add(Localizer["Settings_Error_Saving"], Severity.Error);
		}
	}

	/// <summary>
	/// Переключает видимость страницы модуля
	/// </summary>
	private async Task TogglePageAsync(string route, bool isEnabled)
	{
		try
		{
			if (isEnabled)
			{
				AppSettings.Settings.DisabledRoutes.Remove(route);
			}
			else
			{
				AppSettings.Settings.DisabledRoutes.Add(route);
			}

			await AppSettings.SaveAsync();
			LayoutStateService.NotifyStateChanged();
			Snackbar.Add(Localizer["Settings_Saved_Success"], Severity.Success);
		}
		catch (Exception ex)
		{
			System.Diagnostics.Debug.WriteLine($"[Settings] Error toggling page: {ex.Message}");
			Snackbar.Add(Localizer["Settings_Error_Saving"], Severity.Error);
		}
	}

	private string GetFullRoute(IModule module, INavigationItem item)
	{
		return $"{module.BaseRoute.TrimEnd('/')}/{item.RelativeRoute.TrimStart('/')}";
	}

	public void Dispose()
	{
		ModuleManager.ModuleStateChanged -= OnModuleStateChanged;
		ModuleManager.ModulesBulkRegistered -= OnModulesBulkRegistered;
	}
}