@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<HeadContent>
    @*Markdown resources*@
    <link href="_content/MudBlazor.Markdown/MudBlazor.Markdown.min.css" rel="stylesheet" />
    <script src="_content/MudBlazor.Markdown/MudBlazor.Markdown.min.js"></script>
</HeadContent>

<MudGrid Style="height: calc(100vh - 200px);">
    <MudItem xs="6" Style="height: 100%;">
        <MudTextField T="string"
                      @bind-Value="_markdown"
                      Style="height: 100%;"
                      Lines="40"
                      Variant="Variant.Outlined"
                      Placeholder="Введите Json текст..." />
    </MudItem>
    <MudItem xs="6" Style="height: 100%; overflow-y: auto;">
        <MudPaper Outlined="true" Style="height: 100%; overflow-y: auto;">
            <MudMarkdown Value="@_markdown" />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string _markdown = "# Привет, OmniCore!\n\nЭто **Markdown** редактор.\n\n- Пункт 1\n- Пункт 2";
}