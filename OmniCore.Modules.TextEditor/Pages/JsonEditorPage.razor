@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using MudExtensions

<HeadContent>
    @*CodeBeam resources*@
    <link href="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.css" rel="stylesheet" />
    <script src="_content/CodeBeam.MudBlazor.Extensions/MudExtensions.min.js"></script>

    @* For MudCodeViewer component only (needs CodeBeam.MudBlazor.Extensions.Code package) *@
    @* <link href="_content/CodeBeam.MudBlazor.Extensions.Code/prism/prism.min.css" rel="stylesheet" />
    <script src="_content/CodeBeam.MudBlazor.Extensions.Code/prism/prism.min.js"></script> *@
</HeadContent>

<MudGrid Style="height: calc(100vh - 200px);">
    <MudItem xs="6" Style="height: 100%;">
        <MudTextField T="string"
                      @bind-Value="_json"
                      Lines="40"
                      MaxLines="40"
                      Style="height: 100%;"
                      Class="h-100"
                      Variant="Variant.Outlined"
                      Placeholder="Введите Markdown текст..." />
    </MudItem>
    <MudItem xs="6" Style="height: 100%; overflow-y: auto;">
        <MudPaper Outlined="true" Style="height: 100%; padding: 16px; overflow-y: auto;">
            <MudJsonTreeView Json="@_json" Dense="true" />
        </MudPaper>
    </MudItem>
</MudGrid>

