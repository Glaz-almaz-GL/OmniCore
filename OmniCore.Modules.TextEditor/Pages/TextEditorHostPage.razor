@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Logging
@using MudBlazor
@using OmniCore.Modules.TextEditor.Abstractions.Interfaces
@using OmniCore.Modules.TextEditor.Resources.Languages
@inject IEnumerable<ITextEditor> TextEditors
@inject IStringLocalizer<TextEditorResources> Localizer
@inject ILogger<TextEditorHostPage> Logger
@page "/text-editor/editor"

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 600;">
        @Localizer["Page_Editor_Title"]
    </MudText>

    <MudTabs Elevation="1" Border="true" Rounded="true" ApplyEffectsToContainer="false">
        @foreach (var editor in TextEditors.OrderBy(e => e.Priority).ThenBy(e => e.Title))
        {
            <MudTabPanel Text="@editor.Title" Icon="@editor.Icon">
                <DynamicComponent Type="@editor.TextEditorType" />
            </MudTabPanel>
        }
    </MudTabs>
</MudContainer>

@code {
    protected override void OnInitialized()
    {
        var editorList = TextEditors.ToList();
        Logger.LogDebug($"Found {editorList.Count} editors");
        foreach (var editor in editorList)
        {
            Logger.LogDebug($"Editor: {editor.Title}");
        }
    }
}