@using System.Diagnostics
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Localization
@using MudBlazor
@using OmniCore.Modules.FMMS.Enums
@using OmniCore.Modules.FMMS.Resources.Languages
@using OmniCore.Modules.FMMS.Services
@using OmniCore.Modules.Hash.Abstractions.Interfaces
@inject IStringLocalizer<FmmsResources> Localizer
@inject FmmsSettingsService SettingsService
@inject ISnackbar Snackbar
@inject IHashProviderFactory HashProviderFactory

<MudStack Spacing="4">

    <!-- Секция 1: Общие настройки сканирования -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_General_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudSwitch T="bool"
                           ValueChanged="OnArchiveSettingsChanged"
                           Label="@Localizer["Settings_ScanArchives"]"
                           Color="Color.Primary" />

                <MudSelect T="FileSizeType"
                           ValueChanged="OnSizeTypeSettingChanged"
                           Label="@Localizer["Settings_DisplayedSizeType"]"
                           Variant="Variant.Outlined" Dense="true">
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.Bit">Bit</MudSelectItem>
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.B">B</MudSelectItem>
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.KB">KB</MudSelectItem>
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.MB">MB</MudSelectItem>
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.GB">GB</MudSelectItem>
                    <MudSelectItem T="FileSizeType" Value="@FileSizeType.TB">TB</MudSelectItem>
                </MudSelect>

                <MudNumericField T="int"
                                 ValueChanged="OnMaxFilesSettingsChanged"
                                 Label="@Localizer["Settings_MaxConcurrentFiles"]"
                                 Min="1" Variant="Variant.Outlined" Style="max-width: 200px;" />
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Секция 2: Настройки хеширования -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_Hashing_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle2">@Localizer["Settings_Hashing_Algorithms"]</MudText>
                <MudGrid>
                    @foreach (var a in SettingsService.FilesScanningSettings.Hashing.AlgorithmsToCalculate)
                    {
                        Debug.WriteLine("Alghorithms in settings: " + a);
                    }

                    @foreach (var algo in _availableAlgorithms.Order())
                    {
                        Debug.WriteLine("Availabled alghorithms: " + algo);
                        var isCalculated = SettingsService.FilesScanningSettings.Hashing.AlgorithmsToCalculate.Contains(algo);

                        Debug.WriteLine("Alghorithms to calculate: " + isCalculated);

                        <MudItem xs="12" sm="6" md="4">
                            <MudSwitch T="bool"
                                       Value="@isCalculated"
                                       ValueChanged="@(val => OnAlgorithmToggled(algo, val))"
                                       Label="@algo"
                                       Color="Color.Primary" />
                        </MudItem>
                    }
                </MudGrid>

                <MudDivider />

                <MudStack Row="true" Spacing="4" Wrap="Wrap.Wrap">
                    <MudNumericField T="long"
                                     ValueChanged="OnMaxSizeSettingsChanged"
                                     Label="@Localizer["Settings_Hashing_MaxSize"]"
                                     Min="0" Variant="Variant.Outlined" Style="max-width: 200px;" />

                    <MudSwitch T="bool"
                               ValueChanged="OnCalculateSettingsChanged"
                               Label="@Localizer["Settings_Hashing_Parallel"]"
                               Color="Color.Primary" />

                    <MudNumericField T="int"
                                     ValueChanged="OnParallelismSettingsChanged"
                                     Label="@Localizer["Settings_Hashing_MaxParallelism"]"
                                     Min="1" Variant="Variant.Outlined" Style="max-width: 200px;" />
                </MudStack>
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Секция 3: Видимость колонок -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_Columns_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudText Typo="Typo.subtitle2">@Localizer["Settings_Columns_Standard"]</MudText>
                <MudGrid>
                    @foreach (var kvp in SettingsService.FilesScanningSettings.Columns.StandardColumns)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudSwitch T="bool"
                                       Value="@kvp.Value"
                                       ValueChanged="@(val => OnStandardColumnToggled(kvp.Key, val))"
                                       Label="@GetLocalizedColumnName(kvp.Key)"
                                       Color="Color.Primary" />
                        </MudItem>
                    }
                </MudGrid>

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle2">@Localizer["Settings_Columns_Hashes"]</MudText>
                <MudGrid>
                    @foreach (var kvp in SettingsService.FilesScanningSettings.Columns.HashColumns)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudSwitch T="bool"
                                       Value="@kvp.Value"
                                       ValueChanged="@(val => OnHashColumnToggled(kvp.Key, val))"
                                       Label="@kvp.Key"
                                       Color="Color.Primary" />
                        </MudItem>
                    }
                </MudGrid>
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Секция 4: Правила подсчета страниц -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_PagesRules_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudStack Row="true" Justify="Justify.FlexStart" AlignItems="AlignItems.End">
                    <MudTextField T="string"
                                  @bind-Value="_newRuleExt"
                                  Label="@Localizer["Settings_PagesRules_Extension"]"
                                  Variant="Variant.Outlined" Style="max-width: 150px;"
                                  OnKeyDown="@HandleEnterKeyPages" />
                    <MudNumericField T="int"
                                     @bind-Value="_newRulePages"
                                     Label="@Localizer["Settings_PagesRules_Value"]"
                                     Min="1" Variant="Variant.Outlined" Style="max-width: 150px;" />
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddPageRule">
                        @Localizer["Common_Add"]
                    </MudButton>
                </MudStack>

                @if (SettingsService.FilesScanningSettings.PagesCountCustomRules.Any())
                {
                    <MudTable Items="SettingsService.FilesScanningSettings.PagesCountCustomRules.ToList()" Hover="true" Striped="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>@Localizer["Settings_PagesRules_Extension"]</MudTh>
                            <MudTh>@Localizer["Settings_PagesRules_Value"]</MudTh>
                            <MudTh Style="width:100px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Ext">@context.Key</MudTd>
                            <MudTd DataLabel="Val">@context.Value</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemovePageRule(context.Key))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Localizer["Settings_PagesRules_Empty"]</MudText>
                }
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Секция 5: Кастомные расширения архивов -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_Archives_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                    <MudTextField T="string"
                                  @bind-Value="_newArchiveExt"
                                  Label="@Localizer["Settings_PagesRules_Extension"]"
                                  Placeholder=".rar" Variant="Variant.Outlined" Style="max-width: 200px;"
                                  OnKeyDown="@HandleEnterKey" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddArchiveExtension">
                        @Localizer["Common_Add"]
                    </MudButton>
                </MudStack>

                <MudChipSet T="string">
                    @foreach (var ext in SettingsService.FilesScanningSettings.CustomArchiveExtensions.Order())
                    {
                        <MudChip T="string" Text="@ext" Color="Color.Primary" OnClose="@(() => RemoveArchiveExtension(ext))" CloseIcon="@Icons.Material.Filled.Close" />
                    }
                </MudChipSet>
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Секция 6: Настройки директорий -->
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localizer["Settings_DirectoryScan_Title"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudStack Spacing="3">
                <MudSwitch T="bool"
                           ValueChanged="OnIncludeHiddenSettingsChanged"
                           Label="@Localizer["Settings_IncludeHiddenFolders"]"
                           Color="Color.Primary" />
            </MudStack>
        </MudCardContent>
    </MudCard>

    <!-- Кнопка явного сохранения -->
    <MudStack Row="true" Justify="Justify.FlexEnd">
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveExplicitly" StartIcon="@Icons.Material.Filled.Save">
            @Localizer["Common_Save"]
        </MudButton>
    </MudStack>
</MudStack>

<div style="height: 50px;" />

@code {
    private string _newArchiveExt = "";
    private string _newRuleExt = "";
    private int _newRulePages = 1;
    private List<string> _availableAlgorithms = new();

    protected override async Task OnInitializedAsync()
    {
        _availableAlgorithms = HashProviderFactory.GetAvailableAlgorithms().ToList();
    }

    private string GetLocalizedColumnName(FileColumn column)
    {
        return Localizer[$"Column_{column}"]?.Value ?? column.ToString();
    }

    #region Hashing Logic

    private async Task OnAlgorithmToggled(string algorithm, bool isChecked)
    {
        var hashSettings = SettingsService.FilesScanningSettings.Hashing;
        var columnsSettings = SettingsService.FilesScanningSettings.Columns;

        if (isChecked)
        {
            hashSettings.AlgorithmsToCalculate.Add(algorithm);

            // Автоматически добавляем колонку в настройки видимости
            if (!columnsSettings.HashColumns.ContainsKey(algorithm))
            {
                columnsSettings.HashColumns[algorithm] = true;
            }
        }
        else
        {
            hashSettings.AlgorithmsToCalculate.Remove(algorithm);
        }

        await SaveAsync();
    }

    #endregion

    #region Columns Logic

    private async Task OnStandardColumnToggled(FileColumn column, bool isVisible)
    {
        SettingsService.FilesScanningSettings.Columns.StandardColumns[column] = isVisible;
        await SaveAsync();
    }

    private async Task OnHashColumnToggled(string algorithm, bool isVisible)
    {
        SettingsService.FilesScanningSettings.Columns.HashColumns[algorithm] = isVisible;
        await SaveAsync();
    }

    #endregion

    #region Archive Extensions Logic

    private async Task AddArchiveExtension()
    {
        if (TryNormalizeExtension(_newArchiveExt, out var ext))
        {
            if (SettingsService.FilesScanningSettings.CustomArchiveExtensions.Add(ext))
            {
                _newArchiveExt = "";
                await SaveAsync();
            }
        }
    }

    private async Task RemoveArchiveExtension(string ext)
    {
        SettingsService.FilesScanningSettings.CustomArchiveExtensions.Remove(ext);
        await SaveAsync();
    }

    #endregion

    #region Page Rules Logic

    private async Task AddPageRule()
    {
        if (TryNormalizeExtension(_newRuleExt, out var ext))
        {
            SettingsService.FilesScanningSettings.PagesCountCustomRules[ext] = _newRulePages;
            _newRuleExt = "";
            _newRulePages = 1;
            await SaveAsync();
        }
    }

    private async Task RemovePageRule(string key)
    {
        SettingsService.FilesScanningSettings.PagesCountCustomRules.Remove(key);
        await SaveAsync();
    }

    #endregion

    #region Helpers & Validation

    /// <summary>
    /// Нормализует и валидирует расширение файла.
    /// </summary>
    private bool TryNormalizeExtension(string input, out string normalizedExt)
    {
        normalizedExt = string.Empty;
        if (string.IsNullOrWhiteSpace(input)) return false;

        var ext = input.Trim().ToLowerInvariant();
        if (!ext.StartsWith(".")) ext = "." + ext;

        // Проверка: только буквы, цифры и точка в начале, длина от 2 до 10 символов
        if (!Regex.IsMatch(ext, @"^\.[a-z0-9]{1,9}$"))
        {
            Snackbar.Add(Localizer["Settings_InvalidExtension"], Severity.Warning);
            return false;
        }

        normalizedExt = ext;
        return true;
    }

    private async Task OnIncludeHiddenSettingsChanged(bool value)
    {
        SettingsService.DirectoryScanningSettings.IncludeHidden = value;
        await SaveAsync();
    }

    private async Task OnParallelismSettingsChanged(int value)
    {
        SettingsService.FilesScanningSettings.Hashing.MaxDegreeOfParallelism = value;
        await SaveAsync();
    }

    private async Task OnCalculateSettingsChanged(bool value)
    {
        SettingsService.FilesScanningSettings.Hashing.CalculateInParallel = value;
        await SaveAsync();
    }

    private async Task OnMaxSizeSettingsChanged(long value)
    {
        SettingsService.FilesScanningSettings.Hashing.MaxFileSizeBytes = value;
        await SaveAsync();
    }

    private async Task OnMaxFilesSettingsChanged(int value)
    {
        SettingsService.FilesScanningSettings.MaxConcurrentFileProcessing = value;
        await SaveAsync();
    }

    private async Task OnSizeTypeSettingChanged(FileSizeType value)
    {
        SettingsService.FilesScanningSettings.DisplayedSizeType = value;
        await SaveAsync();
    }

    private async Task OnArchiveSettingsChanged(bool value)
    {
        SettingsService.FilesScanningSettings.ScanArchives = value;
        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        await SettingsService.SaveAsync();
    }

    private async Task SaveExplicitly()
    {
        await SettingsService.SaveAsync();
        Snackbar.Add(Localizer["Settings_Saved_Success"], Severity.Success);
    }

    private async Task HandleEnterKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") await AddArchiveExtension();
    }

    private async Task HandleEnterKeyPages(KeyboardEventArgs args)
    {
        if (args.Key == "Enter") await AddPageRule();
    }

    #endregion
}