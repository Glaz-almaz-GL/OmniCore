@page "/fmms/files_scanner"
@using MudBlazor
@using OmniCore.Modules.FMMS.Enums
@using OmniCore.Modules.FMMS.Models
@using OmniCore.Modules.FMMS.Interfaces
@using OmniCore.Modules.FMMS.Resources.Languages
@using OmniCore.Modules.FMMS.Services
@using CommunityToolkit.Maui.Storage
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Components.Web
@using System.Diagnostics
@using System.Text
@inject IFileScannerService ScannerService
@inject FmmsSettingsService SettingsService
@inject IStringLocalizer<FmmsResources> Localizer
@inject ISnackbar Snackbar
@inject IClipboardService Clipboard

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
	<MudStack Spacing="3">

		<!-- Панель управления -->
		<MudCard>
			<MudCardContent>
				<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
					<MudTextField T="string"
								  @bind-Value="_folderPath"
								  Label="@Localizer["Scanner_FolderPath"]"
								  Variant="Variant.Outlined"
								  ReadOnly="true"
								  Style="flex-grow: 1;" />

					<MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SelectFolderAsync">
						@Localizer["Scanner_SelectFolder"]
					</MudButton>

					@if (!_isScanning)
					{
						<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartScanningAsync" Disabled="@string.IsNullOrWhiteSpace(_folderPath)">
							@Localizer["Scanner_Start"]
						</MudButton>
					}
					else
					{
						<MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="CancelScanning">
							@Localizer["Scanner_Cancel"]
						</MudButton>
					}
				</MudStack>

				@if (_isScanning || _progress > 0)
				{
					<MudProgressLinear Color="Color.Primary" Value="@_progress" Class="mt-4" Indeterminate="@(_progress == 0)" />
				}
			</MudCardContent>
		</MudCard>

		<!-- Таблица результатов с горизонтальной прокруткой -->
		<MudCard>
			<MudCardContent Style="padding: 0;">
				<div @onkeydown="OnDataGridKeyDown" tabindex="0" style="overflow-x: auto; max-height: 100%; overflow-y: auto;">
					<MudDataGrid T="ScannedFile"
								 Items="@_scannedFiles"
								 SelectedItems="@_selectedRows"
								 SelectedItemsChanged="@SelectedItemsChanged"
								 Hover="true"
								 Striped="true"
								 Dense="true"
								 Elevation="0"
								 Outlined="false"
								 HorizontalScrollbar="true"
								 ColumnResizeMode="ResizeMode.Column"
								 Filterable="true"
								 ReadOnly="true"
								 SortMode="SortMode.Single"
								 MultiSelection="true"
								 SelectOnRowClick="true"
								 Bordered="true"
								 RowContextMenuClick="@OpenMenuContent"
								 RowsPerPage="20">
						<Columns>
							<SelectColumn />
							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.Id])
							{
								<PropertyColumn T="ScannedFile" TProperty="int" Property="x => _scannedFiles.IndexOf(x) + 1" Title="@Localizer["Table_Id"]">
									<CellTemplate>
										<MudText Typo="Typo.body2">@(_scannedFiles.IndexOf(context.Item) + 1)</MudText>
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.Name])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.Name" Title="@Localizer["Table_Name"]" />
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.Extension])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.Extension" Title="@Localizer["Table_Extension"]" />
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.Size])
							{
								<PropertyColumn T="ScannedFile" TProperty="long" Filterable="false" Property="x => x.Size" Title="@Localizer["Table_Size"]">
									<CellTemplate>
										<MudText Typo="Typo.body2">@FormatSize(context.Item.Size)</MudText>
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.CompressedSize])
							{
								<PropertyColumn T="ScannedFile" TProperty="long" Property="x => x.CompressedSize" Title="@Localizer["Table_Compressed_Size"]">
									<CellTemplate>
										<MudText Typo="Typo.body2">@FormatSize(context.Item.CompressedSize)</MudText>
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.UnCompressedSize])
							{
								<PropertyColumn T="ScannedFile" TProperty="long" Property="x => x.UnCompressedSize" Title="@Localizer["Table_UnCompressed_Size"]">
									<CellTemplate>
										<MudText Typo="Typo.body2">@FormatSize(context.Item.UnCompressedSize)</MudText>
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.PagesCount])
							{
								<PropertyColumn T="ScannedFile" TProperty="int" Property="x => x.PagesCount" Title="@Localizer["Table_Pages_Count"]">
									<CellTemplate>
										<MudText Typo="Typo.body2">@(context.Item.PagesCount > 0 ? context.Item.PagesCount.ToString() : "-")</MudText>
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.IsArchive])
							{
								<PropertyColumn T="ScannedFile" TProperty="bool" Property="x => x.IsArchive" Title="@Localizer["Table_Is_Archive"]">
									<CellTemplate>
										<MudIcon Icon="@(context.Item.IsArchive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
												 Color="@(context.Item.IsArchive ? Color.Success : Color.Default)"
												 Size="Size.Small" />
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.IsArchiveEntry])
							{
								<PropertyColumn T="ScannedFile" TProperty="bool" Property="x => x.IsArchiveEntry" Title="@Localizer["Table_Is_Archive_Entry"]">
									<CellTemplate>
										<MudIcon Icon="@(context.Item.IsArchiveEntry ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
												 Color="@(context.Item.IsArchiveEntry ? Color.Success : Color.Default)"
												 Size="Size.Small" />
									</CellTemplate>
								</PropertyColumn>
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.FullPath])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.FullPath" Title="@Localizer["Table_Full_Path"]" />
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.MD5])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.MD5" Title="@Localizer["Table_MD5"]" />
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.SHA256])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.SHA256" Title="@Localizer["Table_SHA256"]" />
							}

							@if (SettingsService.Settings.ColumnVisibleSettings[FileColumn.SHA512])
							{
								<PropertyColumn T="ScannedFile" TProperty="string" Property="x => x.SHA512" Title="@Localizer["Table_SHA512"]" />
							}
						</Columns>
						<PagerContent>
							<MudDataGridPager T="ScannedFile" PageSizeOptions="@(new int[] { 20, 50, 100 })" />
						</PagerContent>
					</MudDataGrid>

					<MudMenu DropShadow="true" PositionAtCursor="true" @ref="_contextMenu">
						<MudMenuItem OnClick="@(() => OpenFile(_contextRow?.FullPath))" Icon="@Icons.Material.Outlined.FileOpen">
							@Localizer["Menu_Open_File"]
						</MudMenuItem>
						<MudMenuItem OnClick="@(() => OpenFileDirectory(_contextRow?.FullPath))" Icon="@Icons.Material.Outlined.FolderOpen">
							@Localizer["Menu_Open_Folder"]
						</MudMenuItem>
						<MudMenuItem OnClick="@CopySingleInfoAsync" Icon="@Icons.Material.Outlined.FileCopy">
							@Localizer["Menu_Copy_Info"]
						</MudMenuItem>
						<MudMenuItem OnClick="@CopySingleInfoTsvAsync" Icon="@Icons.Material.TwoTone.FileCopy">
							@Localizer["Menu_Copy_Info_TSV"]
						</MudMenuItem>

						@if (_selectedRows?.Count > 1)
						{
							<MudDivider />
							<MudMenuItem OnClick="@CopySelectedInfoAsync" Icon="@Icons.Material.Outlined.CopyAll">
								@Localizer["Menu_Copy_Info_All"]
							</MudMenuItem>
							<MudMenuItem OnClick="@CopySelectedInfoTsvAsync" Icon="@Icons.Material.TwoTone.CopyAll">
								@Localizer["Menu_Copy_Info_TSV_All"]
							</MudMenuItem>
						}
					</MudMenu>
				</div>
			</MudCardContent>
		</MudCard>
	</MudStack>
</MudContainer>

@code {
	private string _folderPath = string.Empty;
	private bool _isScanning;
	private double _progress;
	private CancellationTokenSource? _cts;
	private ScannedFile? _contextRow;
	private MudMenu _contextMenu = null!;
	private List<ScannedFile> _scannedFiles = new();
	private HashSet<ScannedFile>? _selectedRows = null;

	// Кэш для делегатов форматирования
	private Dictionary<FileColumn, Func<ScannedFile, int, string>>? _columnFormatters;

	private async Task SelectFolderAsync()
	{
		var result = await FolderPicker.Default.PickAsync();
		if (result != null && !string.IsNullOrEmpty(result.Folder?.Path))
		{
			_folderPath = result.Folder.Path;
		}
	}

	private async Task StartScanningAsync()
	{
		_isScanning = true;
		_progress = 0;
		_scannedFiles.Clear();
		_cts = new CancellationTokenSource();

		var progress = new Progress<double>(value =>
		{
			_progress = value;
			StateHasChanged();
		});

		try
		{
			await ScannerService.ScanDirectoryAsync(
				_folderPath,
				SettingsService.Settings,
				progress,
				(file) =>
				{
					_scannedFiles.Add(file);
					StateHasChanged();
				},
				_cts.Token);

			Snackbar.Add(Localizer["Scanner_Completed_Success"], Severity.Success);
		}
		catch (OperationCanceledException)
		{
			Snackbar.Add(Localizer["Scanner_Cancelled"], Severity.Warning);
		}
		catch (Exception ex)
		{
			Snackbar.Add($"{Localizer["Common_Error"]}: {ex.Message}", Severity.Error);
		}
		finally
		{
			_isScanning = false;
			_cts?.Dispose();
			_cts = null;
			StateHasChanged();
		}
	}

	private void CancelScanning()
	{
		_cts?.Cancel();
	}

	private async Task OpenMenuContent(DataGridRowClickEventArgs<ScannedFile> args)
	{
		_contextRow = args.Item;
		await _contextMenu.OpenMenuAsync(args.MouseEventArgs);
	}

	private void SelectedItemsChanged(HashSet<ScannedFile> items)
	{
		_selectedRows = items;
	}

	private string FormatSize(long bytes)
	{
		if (bytes == 0) return "0 B";

		var type = SettingsService.Settings.DisplayedSizeType;
		double size = bytes;

		return type switch
		{
			FileSizeType.B => $"{size} B",
			FileSizeType.KB => $"{(size / 1024.0):F2} KB",
			FileSizeType.MB => $"{(size / 1024.0 / 1024.0):F2} MB",
			FileSizeType.GB => $"{(size / 1024.0 / 1024.0 / 1024.0):F2} GB",
			_ => $"{size} B"
		};
	}

	#region ScannedFileActions

	private void OpenFile(string? filePath)
	{
		if (string.IsNullOrEmpty(filePath)) return;
		try
		{
			Process.Start(new ProcessStartInfo(filePath) { UseShellExecute = true });
		}
		catch (Exception ex)
		{
			Snackbar.Add(ex.Message, Severity.Error, config =>
			{
				config.RequireInteraction = true;
			});
		}
	}

	private void OpenFileDirectory(string? filePath)
	{
		if (string.IsNullOrEmpty(filePath)) return;
		try
		{
			Process.Start(new ProcessStartInfo("explorer.exe", $"/select, {filePath}") { UseShellExecute = true });
		}
		catch (Exception ex)
		{
			Snackbar.Add(ex.Message, Severity.Error, config =>
			{
				config.RequireInteraction = true;
			});
		}
	}

	// Инициализация делегатов форматирования (ленивая или в конструкторе)
	private void InitializeColumnFormatters()
	{
		if (_columnFormatters != null) return;

		_columnFormatters = new Dictionary<FileColumn, Func<ScannedFile, int, string>>
		{
			[FileColumn.Id] = (_, index) => $"{Localizer["Table_Id"]}: {index}",
			[FileColumn.Name] = (file, _) => $"{Localizer["Table_Name"]}: {file.Name}",
			[FileColumn.Extension] = (file, _) => $"{Localizer["Table_Extension"]}: {file.Extension}",
			[FileColumn.Size] = (file, _) => $"{Localizer["Table_Size"]}: {FormatSize(file.Size)}",
			[FileColumn.CompressedSize] = (file, _) => $"{Localizer["Table_Compressed_Size"]}: {FormatSize(file.CompressedSize)}",
			[FileColumn.UnCompressedSize] = (file, _) => $"{Localizer["Table_UnCompressed_Size"]}: {FormatSize(file.UnCompressedSize)}",
			[FileColumn.PagesCount] = (file, _) => $"{Localizer["Table_Pages_Count"]}: {file.PagesCount}",
			[FileColumn.IsArchive] = (file, _) => $"{Localizer["Table_Is_Archive"]}: {file.IsArchive}",
			[FileColumn.IsArchiveEntry] = (file, _) => $"{Localizer["Table_Is_Archive_Entry"]}: {file.IsArchiveEntry}",
			[FileColumn.FullPath] = (file, _) => $"{Localizer["Table_Full_Path"]}: {file.FullPath}",
			[FileColumn.MD5] = (file, _) => $"{Localizer["Table_MD5"]}: {file.MD5}",
			[FileColumn.SHA256] = (file, _) => $"{Localizer["Table_SHA256"]}: {file.SHA256}",
			[FileColumn.SHA512] = (file, _) => $"{Localizer["Table_SHA512"]}: {file.SHA512}"
		};
	}

	/// <summary>
	/// Получает список видимых колонок на основе настроек.
	/// </summary>
	private IEnumerable<KeyValuePair<FileColumn, Func<ScannedFile, int, string>>> GetVisibleFormatters()
	{
		InitializeColumnFormatters();
		return _columnFormatters!.Where(kvp => SettingsService.Settings.ColumnVisibleSettings[kvp.Key]);
	}

	/// <summary>
	/// Получает отформатированную строку для одного файла (Human Readable).
	/// </summary>
	private string GetFileInfoFormatted(ScannedFile file)
	{
		var index = _scannedFiles.IndexOf(file) + 1;
		var sb = new StringBuilder();

		foreach (var formatter in GetVisibleFormatters())
		{
			sb.Append($"{formatter.Value(file, index)} ");
		}

		return sb.ToString().TrimEnd();
	}

	/// <summary>
	/// Получает строку TSV для одного файла (только значения).
	/// </summary>
	private string GetFileInfoTsv(ScannedFile file)
	{
		var index = _scannedFiles.IndexOf(file) + 1;
		var values = GetVisibleFormatters()
			.Select(f =>
			{
				// Берем чистое значение после двоеточия, если оно есть, иначе всё значение
				var formatted = f.Value(file, index);
				var separatorIndex = formatted.IndexOf(':');
				return separatorIndex >= 0
					? formatted.Substring(separatorIndex + 1).Trim()
					: formatted.Trim();
			})
			.ToList();

		return string.Join("\t", values);
	}

	/// <summary>
	/// Получает строку заголовков для TSV.
	/// </summary>
	private string GetTsvHeaders()
	{
		var headers = GetVisibleFormatters()
			.Select(f =>
			{
				var key = f.Key switch
				{
					FileColumn.Id => "Table_Id",
					FileColumn.Name => "Table_Name",
					FileColumn.Extension => "Table_Extension",
					FileColumn.Size => "Table_Size",
					FileColumn.CompressedSize => "Table_Compressed_Size",
					FileColumn.UnCompressedSize => "Table_UnCompressed_Size",
					FileColumn.PagesCount => "Table_Pages_Count",
					FileColumn.IsArchive => "Table_Is_Archive",
					FileColumn.IsArchiveEntry => "Table_Is_Archive_Entry",
					FileColumn.FullPath => "Table_Full_Path",
					FileColumn.MD5 => "Table_MD5",
					FileColumn.SHA256 => "Table_SHA256",
					FileColumn.SHA512 => "Table_SHA512",
					_ => "Unknown"
				};
				return Localizer[key];
			})
			.ToList();

		return string.Join("\t", headers);
	}

	// Действия контекстного меню
	private async Task CopySingleInfoAsync()
	{
		if (_contextRow != null || _selectedRows?.Count > 0)
		{
			ScannedFile file = _contextRow ?? _selectedRows!.First();

			var info = GetFileInfoFormatted(file);
			await Clipboard.WriteTextAsync(info);
			Snackbar.Add(Localizer["Common_Copied"], Severity.Info);
		}
	}

	private async Task CopySingleInfoTsvAsync()
	{
		if (_contextRow != null || _selectedRows?.Count > 0)
		{
			ScannedFile file = _contextRow ?? _selectedRows!.First();

			var info = GetFileInfoTsv(file);
			StringBuilder sb = new();

			sb.AppendLine(GetTsvHeaders());
			sb.AppendLine(info);

			await Clipboard.WriteTextAsync(sb.ToString());
			Snackbar.Add(Localizer["Common_Copied"], Severity.Info);
		}
	}

	private async Task CopySelectedInfoAsync()
	{
		if (_selectedRows?.Count == 0) return;

		var sortedFiles = _selectedRows!
			.Select(file => new { File = file, Index = _scannedFiles.IndexOf(file) })
			.OrderBy(item => item.Index)
			.Select(item => item.File)
			.ToList();

		var sb = new StringBuilder();

		foreach (var file in sortedFiles)
		{
			sb.AppendLine(GetFileInfoFormatted(file));
		}

		await Clipboard.WriteTextAsync(sb.ToString());
		Snackbar.Add(Localizer["Common_Copied"], Severity.Info);
	}

	private async Task CopySelectedInfoTsvAsync()
	{
		if (_selectedRows?.Count == 0) return;

		var sortedFiles = _selectedRows!
			.Select(file => new { File = file, Index = _scannedFiles.IndexOf(file) })
			.OrderBy(item => item.Index)
			.Select(item => item.File)
			.ToList();

		var sb = new StringBuilder();

		// Добавляем заголовки
		sb.AppendLine(GetTsvHeaders());

		foreach (var file in sortedFiles)
		{
			sb.AppendLine(GetFileInfoTsv(file));
		}

		await Clipboard.WriteTextAsync(sb.ToString());
		Snackbar.Add(Localizer["Common_Copied"], Severity.Info);
	}

	#endregion

	private async Task OnDataGridKeyDown(KeyboardEventArgs e)
	{
		if (e.CtrlKey && e.ShiftKey && e.Code == "KeyC")
		{
			await CopySingleInfoTsvAsync();
		}
		else if (e.CtrlKey && e.Code == "KeyC")
		{
			await CopySingleInfoAsync();
		}

		if (_contextRow != null || _selectedRows?.Count > 0)
		{
			ScannedFile file = _contextRow ?? _selectedRows!.First();

			if (e.CtrlKey && e.ShiftKey && e.Code == "KeyO")
			{
				OpenFileDirectory(file.FullPath);
			}
			else if (e.CtrlKey && e.Code == "KeyO")
			{
				OpenFile(file.FullPath);
			}
		}
	}

}