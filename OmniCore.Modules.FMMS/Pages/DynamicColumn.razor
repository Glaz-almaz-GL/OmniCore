@using Microsoft.Extensions.Localization
@using MudBlazor
@using OmniCore.Modules.FMMS.Models
@using OmniCore.Modules.FMMS.Resources.Languages
@inject IStringLocalizer<FmmsResources> Localizer

<TemplateColumn T="ScannedFile" Title="@Localizer[Config.HeaderKey]">
    <CellTemplate>
        <MudText Typo="Typo.body2">
            @Config.ValueSelector(context.Item)
        </MudText>
    </CellTemplate>
</TemplateColumn>

@code {
    [Parameter] public ColumnConfig Config { get; set; } = default!;
}